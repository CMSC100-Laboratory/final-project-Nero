PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/farm-to-table?retryWrites=true&w=majority
CLIENT_URL=http://localhost:5173
NODE_ENV=development
JWT_SECRET=put_some_random_string_here

# Admin seed credentials (required for first-time setup)
ADMIN_SEED_EMAIL=admin@da.gov.ph
ADMIN_SEED_PASSWORD=admin123

# Cloudinary (for product image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
